# ============================================================================
# Student Wellness Dashboard API - Environment Configuration Template
# ============================================================================
# Copy this file to .env and update the values with your actual configuration
#
# IMPORTANT: Never commit the .env file to version control
# Add .env to your .gitignore file
# ============================================================================

# Server Configuration
NODE_ENV=development
PORT=3001

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Database Configuration
# SQL Server Connection Settings
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=StudentWellness
DB_USER=sa
DB_PASSWORD=your_strong_password_here
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Startup safety
# In production this should be false so the API does not boot without a database.
ALLOW_START_WITHOUT_DB=true

# Authentication & Security
# Minimum recommended length: 32 characters
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_app_password_here

# File Upload Configuration (Optional)
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Development Tools
ENABLE_SWAGGER=true
ENABLE_CORS=true
ENABLE_REQUEST_LOGGING=true
ENABLE_MODULES_API=false

# Production Overrides (uncomment for production)
# NODE_ENV=production
# DB_ENCRYPT=true
# DB_TRUST_CERT=false
# ALLOW_START_WITHOUT_DB=false
# ENABLE_SWAGGER=false
# LOG_LEVEL=warn

# ============================================================================
# Environment-Specific Notes:
# ============================================================================
#
# DEVELOPMENT:
# - Use local SQL Server instance
# - Enable all debugging and development tools
# - Use http:// for local connections
#
# PRODUCTION:
# - Use hosted/cloud database
# - Enable encryption and security features
# - Use https:// for all connections
# - Disable development tools
#
# DATABASE SETUP:
# 1. Install SQL Server (Express/Developer edition for development)
# 2. Create the database using: database/student_wellness_database.sql
# 3. Populate data using: database/remaining_students_data.sql
# 4. Update DB_* variables with your connection details
#
# SECURITY NOTES:
# - Generate strong, unique passwords
# - Use environment-specific JWT secrets
# - Never use default passwords in production
# - Regularly rotate passwords and secrets
#
# ============================================================================
